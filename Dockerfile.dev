# ===================================
# Binary-Brain | Dockerfile (Dev)
# ===================================

FROM node:20-alpine

WORKDIR /app

# Instalar dependencias
COPY package.json package-lock.json ./
RUN npm ci

# El código se monta como volumen, no se copia
EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
